# SimpleFlow runs local-first: every variable below is OPTIONAL.
# With no .env.local at all, the app runs with no accounts and
# templates persist to browser storage.

# ——— Hosted mode (accounts + shared templates via Supabase/Postgres) ———
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ——— AI assistant (optional) ———
# ANTHROPIC_API_KEY=your-anthropic-api-key
